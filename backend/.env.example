# ==================== 环境配置 ====================
# 运行环境: development / staging / production
ENVIRONMENT=development

# ==================== DeepSeek API 配置 ====================
# 【必填】DeepSeek API 密钥
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek API 地址
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# LLM 模型名称
LLM_MODEL=deepseek-chat

# ==================== Embedding 配置 ====================
# Embedding 模型名称
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# Embedding 运行设备: cpu / cuda
EMBEDDING_DEVICE=cpu

# Embedding 批处理大小
EMBEDDING_BATCH_SIZE=32

# ==================== 向量数据库配置 ====================
# Chroma 持久化目录
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# 向量集合名称
COLLECTION_NAME=documents

# ==================== 数据库配置 ====================
# 数据库连接 URL
DATABASE_URL=sqlite+aiosqlite:///./data/documents.db

# ==================== Redis 配置 ====================
# Redis 连接 URL
REDIS_URL=redis://localhost:6379/0

# 是否启用 Redis
REDIS_ENABLED=false

# Redis 最大连接数
REDIS_MAX_CONNECTIONS=50

# Redis 超时时间(秒)
REDIS_TIMEOUT=30

# ==================== 服务配置 ====================
# 服务监听地址
HOST=0.0.0.0

# 服务监听端口
PORT=8000

# 日志级别: DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO

# ==================== CORS 配置 ====================
# 允许的 CORS 源（多个用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ==================== RAG 配置 ====================
# 检索返回的最大文档数
RETRIEVAL_TOP_K=5

# LLM 温度参数 (0-2)
TEMPERATURE=0.4

# LLM 最大输出 Token 数 (1-32000)
MAX_TOKENS=2000

# 是否启用流式输出
STREAM=true

# ==================== 文档处理配置 ====================
# 文本分块大小
CHUNK_SIZE=500

# 文本分块重叠大小（必须小于 CHUNK_SIZE）
CHUNK_OVERLAP=50

# 允许的文件扩展名（多个用逗号分隔）
ALLOWED_EXTENSIONS=.pdf,.docx,.doc,.txt,.md

# 最大文件大小 (字节)
MAX_FILE_SIZE=52428800
