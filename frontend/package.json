{
  "name": "intelligent-qa-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "@vueuse/core": "^12.0.0",
    "axios": "^1.7.0",
    "dayjs": "^1.11.0",
    "element-plus": "^2.9.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.9",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.0",
    "postcss": "^8.5.0",
    "prettier": "^3.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^2.2.0"
  }
}
